{
  "env": {
    "browser": true,
    "es2021": true,
    "serviceworker": true
  },
  "extends": ["eslint:recommended", "prettier"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "script"
  },
  "globals": {
    "firebase": "readonly",
    "Chart": "readonly",
    "L": "readonly",
    "jspdf": "readonly",
    "emailjs": "readonly",
    "app": "writable",
    "appUI": "writable",
    "google": "readonly"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-var": "off",
    "prefer-const": "warn",
    "no-console": "warn"
  }
}
